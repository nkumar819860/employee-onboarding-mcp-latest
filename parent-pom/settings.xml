                    </snapshots>
                </pluginRepository>
                
                <pluginRepository>
                    <id>mulesoft-public</id>
                    <name>MuleSoft Public Plugin Repository</name>
                    <url>https://repository.mulesoft.org/nexus/content/repositories/public/</url>
                    <releases>
                        <enabled>true</enabled>
                        <updatePolicy>never</updatePolicy>
                    </releases>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                </pluginRepository>
            </pluginRepositories>
        </profile>
        
        <!-- ✅ Java 17 Profile -->
        <profile>
            <id>java17</id>
            <activation>
                <jdk>17</jdk>
            </activation>
            <properties>
                <maven.compiler.source>17</maven.compiler.source>
                <maven.compiler.target>17</maven.compiler.target>
                <java.version>17</java.version>
                <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
            </properties>
        </profile>
        
        <!-- ✅ CloudHub Profile for Employee Onboarding MCP -->
        <profile>
            <id>cloudhub-employee-onboarding</id>
            <properties>
                <mule.version>4.9.14</mule.version>
                <mule.runtime.version>4.9-java17</mule.runtime.version>
                <mule.maven.plugin.version>4.5.0</mule.maven.plugin.version>
                
