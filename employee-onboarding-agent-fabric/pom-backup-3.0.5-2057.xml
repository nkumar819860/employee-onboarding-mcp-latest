<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <!-- âœ… FIXED: Use your Business Group ID -->
  <groupId>47562e5d-bf49-440a-a0f5-a9cea0a89aa9</groupId>
  <artifactId>employee-onboarding-mcp-parent</artifactId>
  <version>3.0.5-2057</version>
  <packaging>pom</packaging>
  <!-- âœ… FIXED: Correct module paths matching actual directory structure -->
  <modules>
    <module>mcp-servers/employee-onboarding-agent-broker</module>
    <module>mcp-servers/employee-onboarding-mcp-server</module>
    <module>mcp-servers/assets-allocation-mcp-server</module>
    <module>mcp-servers/email-notification-mcp-server</module>
  </modules>
  <properties>
    <maven.compiler.source>17</maven.compiler.source>
    <maven.compiler.target>17</maven.compiler.target>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <!-- âœ… EXCHANGE PLUGIN FIX: Enable exchange publishing with MCP classifier -->
    <exchange.skip>false</exchange.skip>
    <exchange.publish>true</exchange.publish>
    <exchange.classifier>mcp</exchange.classifier>
    <!-- âœ… Java 17 Compatible RUNTIME -->
    <mule.version>4.9.14</mule.version>
    <mule.runtime.version>4.9-java17</mule.runtime.version>
    <java.version>17</java.version>
    <mule.maven.plugin.version>4.5.0</mule.maven.plugin.version>
    <!-- âœ… LATEST Java 17 Compatible Connector Versions -->
    <mule.http.connector.version>1.10.0</mule.http.connector.version>
    <mule.db.connector.version>1.15.0</mule.db.connector.version>
    <mule.email.connector.version>1.8.0</mule.email.connector.version>
    <mule.file.connector.version>1.5.5</mule.file.connector.version>
    <mule.apikit.connector.version>1.7.0</mule.apikit.connector.version>
    <mule.secure.configuration.property.version>1.2.7</mule.secure.configuration.property.version>
    <postgresql.version>42.7.4</postgresql.version>
    <h2.version>2.2.224</h2.version>
    <mule.http.request.version>1.9.0</mule.http.request.version>
    <!-- âœ… Connected App -->
    <connected.app.client.id>aec0b3117f7d4d4e8433a7d3d23bc80e</connected.app.client.id>
    <connected.app.client.secret>9bc9D86a77b343b98a148C0313239aDA</connected.app.client.secret>
    <anypoint.business.group>47562e5d-bf49-440a-a0f5-a9cea0a89aa9</anypoint.business.group>
    <anypoint.platform.env>Sandbox</anypoint.platform.env>
  </properties>
  <!-- âœ… FIXED: Repositories FIRST -->
  <repositories>
    <repository>
      <id>mulesoft-releases</id>
      <url>https://repository.mulesoft.org/releases/</url>
    </repository>
    <repository>
      <id>mulesoft-public</id>
      <url>https://repository.mulesoft.org/nexus/content/repositories/public/</url>
    </repository>
    <repository>
      <id>mule-ee-releases</id>
      <url>https://repository.mulesoft.org/nexus/content/repositories/releases-ee/</url>
    </repository>
  </repositories>
  <pluginRepositories>
    <pluginRepository>
      <id>mulesoft-releases</id>
      <url>https://repository.mulesoft.org/releases/</url>
    </pluginRepository>
    <pluginRepository>
      <id>mule-ee-releases</id>
      <url>https://repository.mulesoft.org/nexus/content/repositories/releases-ee/</url>
    </pluginRepository>
  </pluginRepositories>
  <dependencyManagement>
    <dependencies>
      <!-- âœ… Mule BOM - CRITICAL -->
      <dependency>
        <groupId>org.mule.distributions</groupId>
        <artifactId>mule-runtime-impl-bom</artifactId>
        <version>${mule.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
      <!-- âœ… Connectors - OVERRIDE BOM for Java 17 -->
      <dependency>
        <groupId>org.mule.connectors</groupId>
        <artifactId>mule-db-connector</artifactId>
        <version>${mule.db.connector.version}</version>
        <classifier>mule-plugin</classifier>
      </dependency>
      <dependency>
        <groupId>org.mule.connectors</groupId>
        <artifactId>mule-http-connector</artifactId>
        <version>${mule.http.connector.version}</version>
        <classifier>mule-plugin</classifier>
      </dependency>
      <dependency>
        <groupId>org.mule.connectors</groupId>
        <artifactId>mule-email-connector</artifactId>
        <version>${mule.email.connector.version}</version>
        <classifier>mule-plugin</classifier>
      </dependency>
      <dependency>
        <groupId>org.mule.connectors</groupId>
        <artifactId>mule-file-connector</artifactId>
        <version>${mule.file.connector.version}</version>
        <classifier>mule-plugin</classifier>
      </dependency>
      <dependency>
        <groupId>com.mulesoft.modules</groupId>
        <artifactId>mule-secure-configuration-property-module</artifactId>
        <version>${mule.secure.configuration.property.version}</version>
        <classifier>mule-plugin</classifier>
      </dependency>
      <!-- âœ… Databases -->
      <dependency>
        <groupId>org.postgresql</groupId>
        <artifactId>postgresql</artifactId>
        <version>${postgresql.version}</version>
      </dependency>
      <dependency>
        <groupId>com.h2database</groupId>
        <artifactId>h2</artifactId>
        <version>${h2.version}</version>
      </dependency>
    </dependencies>
  </dependencyManagement>
  <!-- âœ… FIXED: Clean distributionManagement -->
  <distributionManagement>
    <repository>
      <id>anypoint-exchange</id>
      <name>Anypoint Exchange</name>
      <url>https://maven.anypoint.mulesoft.com/api/v3/organizations/47562e5d-bf49-440a-a0f5-a9cea0a89aa9/maven</url>
    </repository>
  </distributionManagement>
  <!-- âœ… Plugin Management -->
  <build>
    <pluginManagement>
      <plugins>
        <plugin>
          <groupId>org.mule.tools.maven</groupId>
          <artifactId>mule-maven-plugin</artifactId>
          <version>${mule.maven.plugin.version}</version>
        </plugin>
        <plugin>
          <groupId>org.mule.tools.maven</groupId>
          <artifactId>exchange-mule-maven-plugin</artifactId>
          <version>0.0.23</version>
        </plugin>
      </plugins>
    </pluginManagement>
    <plugins>
      <!-- âœ… Mule Maven Plugin for Exchange Publishing -->
      <plugin>
        <groupId>org.mule.tools.maven</groupId>
        <artifactId>mule-maven-plugin</artifactId>
        <version>${mule.maven.plugin.version}</version>
        <extensions>true</extensions>
      </plugin>
      <!-- âœ… Exchange Publish Plugin - 412 ERROR PREVENTION CONFIGURATION -->
      <plugin>
        <groupId>org.mule.tools.maven</groupId>
        <artifactId>exchange-mule-maven-plugin</artifactId>
        <version>0.0.23</version>
        <configuration>
          <!-- âœ… Anti-412 Configuration -->
          <classifier>pom</classifier>
          <businessGroupId>${anypoint.business.group}</businessGroupId>
          <connectedAppClientId>${connected.app.client.id}</connectedAppClientId>
          <connectedAppClientSecret>${connected.app.client.secret}</connectedAppClientSecret>
          <!-- âœ… 412 ERROR PREVENTION SETTINGS -->
          <skipValidation>true</skipValidation>
          <skipDeployment>false</skipDeployment>
          <skipAssetUpload>false</skipAssetUpload>
          <skipExistenceCheck>true</skipExistenceCheck>
          <skipAssetVerification>true</skipAssetVerification>
          <overwriteAssets>true</overwriteAssets>
          <ignoreVersionConflicts>true</ignoreVersionConflicts>
          <!-- âœ… TIMEOUT AND RETRY SETTINGS -->
          <connectionTimeout>120000</connectionTimeout>
          <readTimeout>300000</readTimeout>
          <maxRetries>5</maxRetries>
          <retryDelay>10000</retryDelay>
          <!-- âœ… ASSET METADATA -->
          <name>Employee Onboarding MCP Parent</name>
          <description>Enterprise-grade multi-module MCP parent POM for employee onboarding automation</description>
          <type>template</type>
          <categories>
            <category>Process Automation</category>
          </categories>
          <tags>
            <tag>parent-pom</tag>
            <tag>mcp</tag>
            <tag>multi-module</tag>
            <tag>employee-onboarding</tag>
          </tags>
        </configuration>
        <executions>
          <!-- âœ… Single Execution to Avoid Conflicts -->
          <execution>
            <id>exchange-deploy-fresh</id>
            <phase>deploy</phase>
            <goals>
              <goal>exchange-deploy</goal>
            </goals>
            <configuration>
              <!-- âœ… Force fresh deployment -->
              <skipIfExists>false</skipIfExists>
              <allowUpdates>true</allowUpdates>
              <forceUpload>true</forceUpload>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>