              "raw": "{\n    \"query\": \"I need help with onboarding our new Marketing Manager\",\n    \"context\": {\n        \"conversationId\": \"TEST-CONV-004\",\n        \"previousQueries\": [\n            \"What do I need to do for a new hire?\",\n            \"They start next week\"\n        ],\n        \"conversationType\": \"multi-turn\",\n        \"userRole\": \"HR Manager\"\n    }\n}"
