    {
      "name": "🧠 5. NLP & Agent Fabric Integration - AI Interface",
      "item": [
        {
          "name": "🤖 Process Natural Language Query - Create Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"NLP processing successful\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response contains NLP results\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('intent');",
                  "    pm.expect(jsonData).to.have.property('entities');",
                  "    pm.expect(jsonData).to.have.property('confidence');",
                  "});",
                  "",
                  "pm.test(\"Intent correctly identified\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.intent).to.eql('CREATE_EMPLOYEE');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-NLP-Processing-Level",
                "value": "advanced"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"query\": \"Create a new employee named Sarah Wilson with email sarah.wilson@techcorp.com in the Marketing department as a Marketing Specialist starting March 10th\",\n    \"context\": {\n        \"conversationId\": \"TEST-CONV-001\",\n        \"sessionId\": \"TEST-SESS-001\",\n        \"currentUser\": \"hr-admin\"\n    },\n    \"enhancedProcessing\": true,\n    \"includePersonalization\": true\n}"
            },
            "url": {
              "raw": "https://{{react_client_url}}/api/nlp/process-query",
              "protocol": "https",
              "host": ["{{react_client_url}}"],
              "path": ["api", "nlp", "process-query"]
            },
            "description": "🤖 **Natural Language Employee Creation**\n\nProcesses natural language input to create employee profiles using advanced NLP and Agent Fabric intelligence.\n\n**NLP Features:**\n- Intent recognition (CREATE_EMPLOYEE)\n- Entity extraction (names, emails, departments)\n- Sentiment analysis\n- Context awareness\n- Confidence scoring\n\n**Agent Fabric Enhancement:**\n- Intelligent data validation\n- Auto-completion of missing fields\n- Risk assessment\n- Workflow optimization\n\n**Example Queries:**\n- \"Add John Smith to Engineering as Senior Developer\"\n- \"Create employee profile for jane.doe@company.com\"\n- \"Onboard new hire in Marketing department\""
          },
          "response": []
        },
