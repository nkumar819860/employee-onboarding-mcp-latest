      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Set service URLs using correct CloudHub domains",
          "if (!pm.environment.get('agent_broker_url')) {",
          "    pm.environment.set('agent_broker_url', 'agent-broker-mcp-server.us-e1.cloudhub.io');",
          "}",
          "if (!pm.environment.get('employee_onboarding_url')) {",
          "    pm.environment.set('employee_onboarding_url', 'employee-onboarding-mcp-server.us-e1.cloudhub.io');",
          "}",
          "if (!pm.environment.get('asset_allocation_url')) {",
          "    pm.environment.set('asset_allocation_url', 'asset-allocation-mcp-server.us-e1.cloudhub.io');",
          "}",
          "if (!pm.environment.get('notification_url')) {",
          "    pm.environment.set('notification_url', 'notification-service-mcp.us-e1.cloudhub.io');",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test script for all requests",
          "pm.test('Response time is less than 10000ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(10000);",
          "});",
          "",
          "// Log response for debugging",
          "console.log('Response Status:', pm.response.status);",
          "console.log('Response Time:', pm.response.responseTime + 'ms');",
          "if (pm.response.json && typeof pm.response.json === 'function') {",
          "    try {",
          "        console.log('Response Body:', JSON.stringify(pm.response.json(), null, 2));",
          "    } catch (e) {",
          "        console.log('Response Text:', pm.response.text());",
          "    }",
          "}"
        ]
      }
    }
  ],
