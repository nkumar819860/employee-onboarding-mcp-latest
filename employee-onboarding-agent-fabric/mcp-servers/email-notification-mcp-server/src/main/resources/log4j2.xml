<?xml version="1.0" encoding="utf-8"?>
<Configuration>
    <Properties>
        <!-- Service name for this MCP service -->
        <Property name="serviceName">notification-mcp</Property>
        <Property name="logPattern">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level [%X{correlationId}] [%X{processorPath}] [%c{1}] - %msg%n</Property>
        <Property name="errorPattern">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level [%X{correlationId}] [%X{processorPath}] [%c{1}] - %msg%n%throwable</Property>
    </Properties>

    <Appenders>
        <!-- Main application log file -->
        <RollingFile name="ApplicationLog" 
                     fileName="${sys:mule.home}${sys:file.separator}logs${sys:file.separator}${serviceName}.log"
                     filePattern="${sys:mule.home}${sys:file.separator}logs${sys:file.separator}${serviceName}-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${logPattern}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="50 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30" compressionLevel="9"/>
        </RollingFile>

        <!-- Error-only log file -->
        <RollingFile name="ErrorLog" 
                     fileName="${sys:mule.home}${sys:file.separator}logs${sys:file.separator}${serviceName}-error.log"
                     filePattern="${sys:mule.home}${sys:file.separator}logs${sys:file.separator}${serviceName}-error-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${errorPattern}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="20 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30" compressionLevel="9"/>
            <Filters>
                <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
        </RollingFile>

        <!-- Performance monitoring log -->
        <RollingFile name="PerformanceLog" 
                     fileName="${sys:mule.home}${sys:file.separator}logs${sys:file.separator}${serviceName}-performance.log"
                     filePattern="${sys:mule.home}${sys:file.separator}logs${sys:file.separator}${serviceName}-performance-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] [%X{correlationId}] [PERF] %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="20 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="15" compressionLevel="9"/>
        </RollingFile>

        <!-- Console appender for development -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%highlight{${logPattern}}{FATAL=red, ERROR=red, WARN=yellow, INFO=green, DEBUG=blue, TRACE=white}"/>
        </Console>

        <!-- Audit log for security and compliance -->
        <RollingFile name="AuditLog" 
                     fileName="${sys:mule.home}${sys:file.separator}logs${sys:file.separator}${serviceName}-audit.log"
                     filePattern="${sys:mule.home}${sys:file.separator}logs${sys:file.separator}${serviceName}-audit-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] [%X{correlationId}] [%X{userId:-SYSTEM}] [%X{clientIP:-UNKNOWN}] [AUDIT] %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="20 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="90" compressionLevel="9"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- MCP Framework Loggers -->
        <AsyncLogger name="com.mulesoft.mcp" level="INFO" additivity="false">
            <AppenderRef ref="ApplicationLog"/>
            <AppenderRef ref="ErrorLog"/>
            <AppenderRef ref="Console"/>
        </AsyncLogger>

        <!-- Performance Logger -->
        <AsyncLogger name="PERFORMANCE" level="INFO" additivity="false">
            <AppenderRef ref="PerformanceLog"/>
        </AsyncLogger>

        <!-- Audit Logger -->
        <AsyncLogger name="AUDIT" level="INFO" additivity="false">
            <AppenderRef ref="AuditLog"/>
        </AsyncLogger>

        <!-- HTTP Client/Server Loggers -->
        <AsyncLogger name="org.mule.service.http" level="WARN"/>
        <AsyncLogger name="org.mule.extension.http" level="WARN"/>
        <AsyncLogger name="org.mule.service.http.impl.service.HttpMessageLogger" level="WARN"/>

        <!-- Database Loggers -->
        <AsyncLogger name="org.mule.extension.db" level="INFO"/>
        <AsyncLogger name="com.zaxxer.hikari" level="WARN"/>
        <AsyncLogger name="org.h2" level="WARN"/>

        <!-- Email Connector Logger -->
        <AsyncLogger name="org.mule.extension.email" level="INFO"/>

        <!-- Mule Runtime Loggers -->
        <AsyncLogger name="org.mule.runtime.core.internal.processor.LoggerMessageProcessor" level="INFO"/>
        <AsyncLogger name="org.mule.runtime.core" level="WARN"/>
        <AsyncLogger name="org.mule.runtime.module" level="WARN"/>

        <!-- Agent/KeyStore Warning Suppressions -->
        <AsyncLogger name="com.mulesoft.agent.AgentPlugin" level="ERROR"/>
        <AsyncLogger name="com.mulesoft.agent.services.EncryptionService" level="ERROR"/>

        <!-- MCP Connector Logger -->
        <AsyncLogger name="org.mule.extension.mcp" level="INFO"/>

        <!-- Third-party Library Loggers -->
        <AsyncLogger name="org.jetel" level="WARN"/>
        <AsyncLogger name="Tracking" level="WARN"/>
        <AsyncLogger name="org.springframework" level="WARN"/>
        <AsyncLogger name="org.apache" level="WARN"/>

        <!-- Root Logger -->
        <AsyncRoot level="INFO">
            <AppenderRef ref="ApplicationLog"/>
            <AppenderRef ref="ErrorLog"/>
            <AppenderRef ref="Console"/>
        </AsyncRoot>
    </Loggers>
</Configuration>
