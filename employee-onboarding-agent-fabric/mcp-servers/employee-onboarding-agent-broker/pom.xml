<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>47562e5d-bf49-440a-a0f5-a9cea0a89aa9</groupId>
		<artifactId>employee-onboarding-mcp-parent</artifactId>
		<version>3.0.1</version>
		<relativePath>../../pom.xml</relativePath>
	</parent>
	<!-- ✅ GroupId matches org -->
	<groupId>47562e5d-bf49-440a-a0f5-a9cea0a89aa9</groupId>
	<artifactId>employee-onboarding-agent-broker</artifactId>
	<version>2.0.4</version>
	<packaging>mule-application</packaging>
	<name>employee-onborading-agent-broker</name>
	<description>Agent Broker MCP Server for Employee Onboarding Process Orchestration</description>
	<properties>
		<maven.compiler.source>17</maven.compiler.source>
		<maven.compiler.target>17</maven.compiler.target>
		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<!-- ✅ Exchange Metadata -->
		<exchange.skip>false</exchange.skip>
		<exchange.publish>true</exchange.publish>
		<exchange.assetId>employee-onboarding-agent-broker</exchange.assetId>
		<!-- Use MCP classifier for MCP server applications -->
		<exchange.classifier>mcp</exchange.classifier>
		<tags>Agent Broker,MCP Server,Process Orchestration,Employee Onboarding,Workflow Management</tags>
		<!-- ✅ CloudHub Properties -->
		<mule.version>4.9.14</mule.version>
		<mule.runtime.version>4.9-java17</mule.runtime.version>
		<mule.maven.plugin.version>4.5.0</mule.maven.plugin.version>
		<application.name>employee-onboarding-agent-broker</application.name>
		<anypoint.business.group>47562e5d-bf49-440a-a0f5-a9cea0a89aa9</anypoint.business.group>
		<anypoint.platform.env>Sandbox</anypoint.platform.env>
		<cloudhub.region>us-east-1</cloudhub.region>
		<cloudhub.workers>1</cloudhub.workers>
		<cloudhub.worker.type>MICRO</cloudhub.worker.type>
		<anypoint.platform.client_id>aec0b3117f7d4d4e8433a7d3d23bc80e</anypoint.platform.client_id>
		<anypoint.platform.client_secret>9bc9D86a77b343b98a148C0313239aDA</anypoint.platform.client_secret>
	</properties>
	<distributionManagement>
		<repository>
			<id>anypoint-exchange</id>
			<name>Anypoint Exchange</name>
			<url>https://maven.anypoint.mulesoft.com/api/v3/organizations/47562e5d-bf49-440a-a0f5-a9cea0a89aa9/maven</url>
		</repository>
	</distributionManagement>
	<repositories>
		<repository>
			<id>anypoint-exchange</id>
			<name>Anypoint Exchange V3</name>
			<url>https://maven.anypoint.mulesoft.com/api/v3/maven</url>
			<layout>default</layout>
		</repository>
		<repository>
			<id>anypoint-exchange-v3</id>
			<name>Anypoint Exchange V3</name>
			<url>https://maven.anypoint.mulesoft.com/api/v3/maven</url>
			<layout>default</layout>
		</repository>
	</repositories>
	<dependencies>
		<dependency>
			<groupId>org.mule.modules</groupId>
			<artifactId>mule-apikit-module</artifactId>
			<version>1.11.1</version>
			<classifier>mule-plugin</classifier>
		</dependency>
		<dependency>
			<groupId>org.mule.connectors</groupId>
			<artifactId>mule-http-connector</artifactId>
			<classifier>mule-plugin</classifier>
		</dependency>
		<dependency>
			<groupId>org.mule.connectors</groupId>
			<artifactId>mule-db-connector</artifactId>
			<classifier>mule-plugin</classifier>
		</dependency>
		<dependency>
			<groupId>org.mule.connectors</groupId>
			<artifactId>mule-sockets-connector</artifactId>
			<version>1.2.7</version>
			<classifier>mule-plugin</classifier>
		</dependency>
		<!-- ✅ MCP Connector for Agent Broker - Commented out until available -->
		<!-- <dependency> <groupId>com.mulesoft.connectors</groupId> <artifactId>mule-mcp-connector</artifactId> 
			<version>1.0.0</version> <classifier>mule-plugin</classifier> </dependency> -->
		<dependency>
			<groupId>org.postgresql</groupId>
			<artifactId>postgresql</artifactId>
		</dependency>
		<dependency>
			<groupId>com.h2database</groupId>
			<artifactId>h2</artifactId>
			<scope>runtime</scope>
		</dependency>
	</dependencies>
	<build>
		<plugins>
			<!-- ✅ Mule Maven Plugin - Exchange + CloudHub -->
			<plugin>
				<groupId>org.mule.tools.maven</groupId>
				<artifactId>mule-maven-plugin</artifactId>
				<version>${mule.maven.plugin.version}</version>
				<extensions>true</extensions>
				<configuration>
					<!-- ✅ Shared Libraries -->
					<sharedLibraries>
						<sharedLibrary>
							<groupId>com.h2database</groupId>
							<artifactId>h2</artifactId>
						</sharedLibrary>
						<sharedLibrary>
							<groupId>org.postgresql</groupId>
							<artifactId>postgresql</artifactId>
						</sharedLibrary>
					</sharedLibraries>
					<!-- ✅ CloudHub Deployment -->
					<cloudHubDeployment>
						<uri>https://anypoint.mulesoft.com</uri>
						<muleVersion>${mule.runtime.version}</muleVersion>
						<javaVersion>17</javaVersion>
						<businessGroupId>${anypoint.business.group}</businessGroupId>
						<!-- Keep secrets in settings.xml (recommended) -->
						<connectedAppClientId>${anypoint.platform.client_id}</connectedAppClientId>
						<connectedAppClientSecret>${anypoint.platform.client_secret}</connectedAppClientSecret>
						<connectedAppGrantType>client_credentials</connectedAppGrantType>
						<applicationName>${application.name}</applicationName>
						<environment>${anypoint.platform.env}</environment>
						<region>${cloudhub.region}</region>
						<workers>${cloudhub.workers}</workers>
						<workerType>${cloudhub.worker.type}</workerType>
						<objectStoreV2>true</objectStoreV2>
						<properties>
							<keyValuePairs>
								<keyValuePair>
									<key>env</key>
									<value>${anypoint.platform.env}</value>
								</keyValuePair>
								<keyValuePair>
									<key>http.port</key>
									<value>8081</value>
								</keyValuePair>
								<keyValuePair>
									<key>https.port</key>
									<value>8082</value>
								</keyValuePair>
								<keyValuePair>
									<key>mule.env</key>
									<value>Sandbox</value>
								</keyValuePair>
								<keyValuePair>
									<key>secure.key</key>
									<value>mule</value>
								</keyValuePair>
								<keyValuePair>
									<key>anypoint.platform.visualizer</key>
									<value>true</value>
								</keyValuePair>
								<keyValuePair>
									<key>anypoint.platform.visualizer.displayName</key>
									<value>Agent Broker MCP Server</value>
								</keyValuePair>
								<keyValuePair>
									<key>anypoint.platform.visualizer.layer</key>
									<value>Agent</value>
								</keyValuePair>
							</keyValuePairs>
						</properties>
					</cloudHubDeployment>
				</configuration>
			</plugin>
			<!-- ✅ Exchange Maven Plugin - Enhanced Configuration with Asset Files -->
			<plugin>
				<groupId>org.mule.tools.maven</groupId>
				<artifactId>exchange-mule-maven-plugin</artifactId>
				<version>0.0.23</version>
				<configuration>
					<!-- ✅ Global Configuration -->
					<classifier>${exchange.classifier}</classifier>
					<businessGroupId>${anypoint.business.group}</businessGroupId>
					<connectedAppClientId>${anypoint.platform.client_id}</connectedAppClientId>
					<connectedAppClientSecret>${anypoint.platform.client_secret}</connectedAppClientSecret>
					<skipValidation>false</skipValidation>
					<skipDeployment>false</skipDeployment>
					
					<!-- ✅ Enhanced Asset Documentation -->
					<includeReadme>false</includeReadme>
					<includeApiSpec>true</includeApiSpec>
					<apiSpecPath>src/main/resources/api/agent-broker-mcp-api.yaml</apiSpecPath>
					
					<!-- ✅ Additional Asset Files -->
					<assetFiles>
						<assetFile>
							<source>src/main/resources/api/agent-broker-mcp-api.yaml</source>
							<target>api/agent-broker-mcp-api.yaml</target>
						</assetFile>
						<assetFile>
							<source>exchange.json</source>
							<target>exchange.json</target>
						</assetFile>
						<assetFile>
							<source>mule-artifact.json</source>
							<target>mule-artifact.json</target>
						</assetFile>
					</assetFiles>
					
					<!-- ✅ Asset Metadata Enhancement -->
					<categories>
						<category>MCP Server</category>
						<category>Employee Onboarding</category>
						<category>Agent Broker</category>
						<category>Process Orchestration</category>
					</categories>
					
					<!-- ✅ Custom Fields -->
					<customFields>
						<customField>
							<name>mcp-server-type</name>
							<value>agent-broker</value>
						</customField>
						<customField>
							<name>integration-pattern</name>
							<value>orchestration</value>
						</customField>
						<customField>
							<name>supported-operations</name>
							<value>orchestrate-employee-onboarding,get-onboarding-status,retry-failed-step,think</value>
						</customField>
						<customField>
							<name>runtime-version</name>
							<value>${mule.runtime.version}</value>
						</customField>
					</customFields>
				</configuration>
				<executions>
					<!-- ✅ Main Deploy: Only during deploy phase -->
					<execution>
						<id>deploy</id>
						<phase>deploy</phase>
						<goals>
							<goal>exchange-deploy</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>
</project>
