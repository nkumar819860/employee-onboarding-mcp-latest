            <section id="active-eks-architecture" class="card">
                <h2>🏗️ Active-Active EKS RTF Architecture</h2>
                
                <h3>🌐 Multi-Region Active-Active Deployment</h3>
                <div class="architecture-diagram">
                    <div class="diagram-title">
                        <h4>ACTIVE-ACTIVE EKS RTF DR ARCHITECTURE</h4>
                    </div>
                    
                    <div class="regions-container">
                        <!-- Primary Region -->
                        <div class="region-column">
                            <div class="region-header">PRIMARY REGION (us-east-1)</div>
                            
                            <!-- EKS Cluster East -->
                            <div class="cluster-box primary-cluster">
                                <div class="cluster-title">
                                    <span class="cluster-icon">🏗️</span>
                                    EKS CLUSTER - EAST
                                </div>
                                <div class="status-indicators">
                                    <span class="status-item">● Status: <span class="status-active">ACTIVE</span></span>
                                    <span class="status-item">● Health: <span class="status-healthy">✅ Healthy</span></span>
                                </div>
                                
                                <!-- RTF Nodes -->
                                <div class="component-box rtf-nodes">
                                    <div class="component-title">
                                        <span class="component-icon">⚡</span>
                                        RTF NODES (3x)
                                    </div>
                                    <ul class="feature-list">
                                        <li>• m5.xlarge x3</li>
                                        <li>• Auto-scaling 1-10</li>
                                        <li>• Health Monitoring</li>
                                        <li>• CPU: <span class="metric-value">25%</span> | RAM: <span class="metric-value">45%</span></li>
                                    </ul>
                                </div>
                                
                                <!-- Mule Applications -->
                                <div class="component-box mule-apps">
                                    <div class="component-title">
                                        <span class="component-icon">🔧</span>
                                        MULE APPLICATIONS
                                    </div>
                                    <ul class="feature-list">
                                        <li>• Employee Onboarding</li>
                                        <li>• Asset Allocation</li>
                                        <li>• Notification Service</li>
                                        <li>• Agent Broker</li>
                                        <li>• Load: <span class="metric-value">2.3k req/min</span></li>
                                    </ul>
                                </div>
                            </div>
                            
                            <!-- Database Primary -->
                            <div class="connection-line down"></div>
                            <div class="database-box primary-db">
                                <div class="db-title">
                                    <span class="db-icon">🗄️</span>
                                    RDS POSTGRES (PRIMARY)
                                </div>
                                <ul class="feature-list">
                                    <li>• Multi-AZ: us-east-1a,1b</li>
                                    <li>• Automated Backups: <span class="status-healthy">✅</span></li>
                                    <li>• Encryption: AES-256</li>
                                    <li>• RPO: < 5 min</li>
                                    <li>• Size: 45GB | IOPS: 3000</li>
                                </ul>
                            </div>
                            
                            <!-- Load Balancer -->
                            <div class="connection-line down"></div>
                            <div class="loadbalancer-box">
                                <div class="lb-title">
                                    <span class="lb-icon">⚖️</span>
                                    APPLICATION LOAD BALANCER
                                </div>
                                <ul class="feature-list">
                                    <li>• Health Checks: 30s</li>
                                    <li>• SSL Termination: TLS 1.3</li>
                                    <li>• HIPAA Compliant: <span class="status-healthy">✅</span></li>
                                    <li>• Throughput: <span class="metric-value">1.2k req/s</span></li>
                                </ul>
                            </div>
                        </div>
                        
                        <!-- Connection Between Regions -->
                        <div class="cross-region-connection">
                            <div class="sync-indicator">
                                <span class="sync-arrow">↔️</span>
                                <div class="sync-label">Sync Repl</div>
                            </div>
                        </div>
                        
                        <!-- Secondary Region -->
                        <div class="region-column">
                            <div class="region-header">SECONDARY REGION (us-west-2)</div>
                            
                            <!-- EKS Cluster West -->
                            <div class="cluster-box secondary-cluster">
                                <div class="cluster-title">
                                    <span class="cluster-icon">🏗️</span>
                                    EKS CLUSTER - WEST
                                </div>
                                <div class="status-indicators">
                                    <span class="status-item">● Status: <span class="status-active">ACTIVE</span></span>
                                    <span class="status-item">● Health: <span class="status-healthy">✅ Healthy</span></span>
                                </div>
                                
                                <!-- RTF Nodes -->
                                <div class="component-box rtf-nodes">
                                    <div class="component-title">
                                        <span class="component-icon">⚡</span>
                                        RTF NODES (3x)
                                    </div>
                                    <ul class="feature-list">
                                        <li>• m5.xlarge x3</li>
                                        <li>• Auto-scaling 1-10</li>
                                        <li>• Health Monitoring</li>
                                        <li>• CPU: <span class="metric-value">23%</span> | RAM: <span class="metric-value">42%</span></li>
                                    </ul>
                                </div>
                                
                                <!-- Mule Applications -->
                                <div class="component-box mule-apps">
                                    <div class="component-title">
                                        <span class="component-icon">🔧</span>
                                        MULE APPLICATIONS
                                    </div>
                                    <ul class="feature-list">
                                        <li>• Employee Onboarding</li>
                                        <li>• Asset Allocation</li>
                                        <li>• Notification Service</li>
                                        <li>• Agent Broker</li>
                                        <li>• Load: <span class="metric-value">2.1k req/min</span></li>
                                    </ul>
                                </div>
                            </div>
                            
                            <!-- Database Standby -->
                            <div class="connection-line down"></div>
                            <div class="database-box secondary-db">
                                <div class="db-title">
                                    <span class="db-icon">🗄️</span>
                                    RDS POSTGRES (STANDBY)
                                </div>
                                <ul class="feature-list">
                                    <li>• Cross-Region Replica</li>
                                    <li>• Auto Promotion: <span class="status-healthy">✅</span></li>
                                    <li>• Encryption: AES-256</li>
                                    <li>• RTO: < 30 sec</li>
                                    <li>• Size: 45GB | IOPS: 3000</li>
                                </ul>
                            </div>
                            
                            <!-- Load Balancer -->
                            <div class="connection-line down"></div>
                            <div class="loadbalancer-box">
                                <div class="lb-title">
                                    <span class="lb-icon">⚖️</span>
                                    APPLICATION LOAD BALANCER
                                </div>
                                <ul class="feature-list">
                                    <li>• Health Checks: 30s</li>
                                    <li>• SSL Termination: TLS 1.3</li>
                                    <li>• HIPAA Compliant: <span class="status-healthy">✅</span></li>
                                    <li>• Throughput: <span class="metric-value">1.1k req/s</span></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Global Traffic Manager -->
                    <div class="global-section">
                        <div class="connection-convergence"></div>
                        <div class="global-manager">
                            <div class="global-title">
                                <span class="global-icon">🌐</span>
                                GLOBAL TRAFFIC MANAGER & DNS FAILOVER
                            </div>
                            <div class="global-features">
                                <div class="feature-row">
                                    <span class="feature-bullet">🔍</span>
                                    <span>Route 53 Health Checks</span>
                                </div>
                                <div class="feature-row">
                                    <span class="feature-bullet">⚖️</span>
                                    <span>Weighted Routing Policy (50/50 traffic distribution)</span>
                                </div>
                                <div class="feature-row">
                                    <span class="feature-bullet">⚡</span>
                                    <span>Automatic Failover < 30 seconds</span>
                                </div>
                                <div class="feature-row">
                                    <span class="feature-bullet">🌍</span>
                                    <span>Global Load Balancing</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <style>
