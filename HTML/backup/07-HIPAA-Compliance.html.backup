            <section id="dr-strategy" class="card">
                <h2>🔄 Disaster Recovery Strategy</h2>
                
                <div class="alert alert-warning">
                    <h4>⚠️ DR Objectives & SLAs</h4>
                    <ul>
                        <li><strong>Recovery Time Objective (RTO):</strong> < 30 seconds</li>
                        <li><strong>Recovery Point Objective (RPO):</strong> < 5 minutes</li>
                        <li><strong>Target Availability:</strong> 99.99% uptime</li>
                        <li><strong>Data Loss Tolerance:</strong> Zero for critical PHI/PII</li>
                    </ul>
                </div>

                <h3>🎯 DR Scenarios & Response</h3>
                <div class="component-grid">
                    <div class="nav-card">
                        <h4>🔥 Regional Outage</h4>
                        <ul class="nav-card-features">
                            <li>Automatic DNS failover</li>
                            <li>Route 53 health checks</li>
                            <li>Database promotion</li>
                            <li>Traffic rerouting</li>
                            <li>Stakeholder notification</li>
                        </ul>
                    </div>
                    <div class="nav-card">
                        <h4>💾 Data Center Failure</h4>
                        <ul class="nav-card-features">
                            <li>Multi-AZ deployment</li>
                            <li>Cross-zone replication</li>
                            <li>Automated failover</li>
                            <li>Load balancer updates</li>
                            <li>Service continuity</li>
                        </ul>
                    </div>
                    <div class="nav-card">
                        <h4>🛡️ Security Incident</h4>
                        <ul class="nav-card-features">
                            <li>Immediate isolation</li>
                            <li>Forensic analysis</li>
                            <li>Backup restoration</li>
