    </footer>

    <!-- JavaScript -->
    <script src="common-scripts.js"></script>
    <script>
        // HIPAA-specific JavaScript functionality
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize compliance monitoring
            initializeComplianceMonitoring();
            
            // Set up security event handlers
            setupSecurityEventHandlers();
            
            // Initialize performance metrics
            initializePerformanceMetrics();
            
            // Setup DR status monitoring
            setupDRStatusMonitoring();
        });

        function initializeComplianceMonitoring() {
            // Compliance monitoring logic
            console.log('HIPAA Compliance monitoring initialized');
            
            // Simulate real-time compliance metrics
            setInterval(updateComplianceMetrics, 30000); // Update every 30 seconds
        }

        function setupSecurityEventHandlers() {
            // Security event handling
            document.addEventListener('securityEvent', function(event) {
                console.log('Security event detected:', event.detail);
                // Handle security events appropriately
            });
        }

        function initializePerformanceMetrics() {
            // Performance metrics tracking
            const metricsEndpoint = '/api/metrics/performance';
            
            setInterval(async () => {
                try {
                    const response = await fetch(metricsEndpoint);
                    const metrics = await response.json();
                    updatePerformanceDisplay(metrics);
                } catch (error) {
                    console.error('Failed to fetch performance metrics:', error);
                }
            }, 60000); // Update every minute
        }

        function setupDRStatusMonitoring() {
            // Disaster recovery status monitoring
            const drStatusEndpoint = '/api/dr/status';
            
            setInterval(async () => {
                try {
                    const response = await fetch(drStatusEndpoint);
                    const status = await response.json();
                    updateDRStatusDisplay(status);
                } catch (error) {
                    console.error('Failed to fetch DR status:', error);
                }
            }, 15000); // Update every 15 seconds
        }

        function updateComplianceMetrics() {
            // Update compliance metrics display
            const complianceScore = Math.floor(Math.random() * 3) + 97; // 97-99%
            const complianceElement = document.querySelector('.metric-card .metric-value');
            if (complianceElement) {
                complianceElement.textContent = complianceScore + '%';
            }
        }

        function updatePerformanceDisplay(metrics) {
            // Update performance metrics in the UI
            if (metrics && metrics.responseTime) {
                const responseTimeElements = document.querySelectorAll('[data-metric="response-time"]');
                responseTimeElements.forEach(element => {
                    element.textContent = metrics.responseTime + 'ms';
                });
            }
        }

        function updateDRStatusDisplay(status) {
            // Update DR status indicators
            const statusIndicators = document.querySelectorAll('.status-dot');
            statusIndicators.forEach(indicator => {
                if (status && status.operational) {
                    indicator.className = 'status-dot status-operational';
                } else {
                    indicator.className = 'status-dot status-warning';
                }
            });
        }

        // Accessibility enhancements
        function enhanceAccessibility() {
            // Add keyboard navigation support
            const navCards = document.querySelectorAll('.nav-card');
            navCards.forEach((card, index) => {
                card.setAttribute('tabindex', '0');
                card.setAttribute('role', 'button');
                
                card.addEventListener('keydown', function(event) {
                    if (event.key === 'Enter' || event.key === ' ') {
                        event.preventDefault();
                        card.click();
                    }
                });
            });

            // Add ARIA labels for better screen reader support
            const metricCards = document.querySelectorAll('.metric-card');
            metricCards.forEach(card => {
                const value = card.querySelector('.metric-value').textContent;
                const label = card.querySelector('.metric-label').textContent;
                card.setAttribute('aria-label', `${label}: ${value}`);
            });
        }

        // Initialize accessibility enhancements
        document.addEventListener('DOMContentLoaded', enhanceAccessibility);
    </script>
</body>
</html>

