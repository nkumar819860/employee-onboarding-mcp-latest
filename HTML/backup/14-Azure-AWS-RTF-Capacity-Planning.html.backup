            <!-- Auto-scaling Configuration -->
            <div class="card">
                <h2>📈 Auto-scaling Strategy & Configuration</h2>
                <p>Detailed auto-scaling configurations for optimal resource utilization and cost management.</p>
                
                <div class="yaml-block">
# Horizontal Pod Autoscaler Configuration for Employee Onboarding
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: employee-onboarding-hpa
  namespace: rtf
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: employee-onboarding-app
  minReplicas: 2
  maxReplicas: 12
  metrics:
  - type: Resource
    resource:
      name: cpu
      target:
        type: Utilization
        averageUtilization: 70
  - type: Resource
    resource:
      name: memory
      target:
        type: Utilization
        averageUtilization: 80
  behavior:
    scaleDown:
      stabilizationWindowSeconds: 300
      policies:
      - type: Percent
        value: 25
        periodSeconds: 60
    scaleUp:
      stabilizationWindowSeconds: 60
      policies:
      - type: Percent
        value: 50
        periodSeconds: 60
        
---
# Cluster Autoscaler Configuration
apiVersion: apps/v1
kind: Deployment
metadata:
  name: cluster-autoscaler
  namespace: kube-system
spec:
  template:
    spec:
      containers:
      - image: k8s.gcr.io/autoscaling/cluster-autoscaler:v1.28.0
        name: cluster-autoscaler
        command:
        - ./cluster-autoscaler
        - --v=4
        - --stderrthreshold=info
        - --cloud-provider=aws # or azure
        - --skip-nodes-with-local-storage=false
        - --expander=least-waste
        - --node-group-auto-discovery=asg:tag=k8s.io/cluster-autoscaler/enabled,k8s.io/cluster-autoscaler/rtf-cluster
        - --scale-down-delay-after-add=10m
        - --scale-down-unneeded-time=10m</div>

                <h3>🎯 Scaling Thresholds & Targets</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Metric</th>
                            <th>Scale Up Threshold</th>
                            <th>Scale Down Threshold</th>
                            <th>Target Range</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>CPU Utilization</strong></td>
                            <td>> 80%</td>
                            <td>< 50%</td>
                            <td>60-80%</td>
                            <td>HPA + CA</td>
                        </tr>
                        <tr>
                            <td><strong>Memory Utilization</strong></td>
                            <td>> 85%</td>
                            <td>< 40%</td>
                            <td>60-85%</td>
                            <td>HPA + CA</td>
                        </tr>
                        <tr>
                            <td><strong>Request Queue</strong></td>
                            <td>> 100 requests</td>
                            <td>< 10 requests</td>
                            <td>10-50 requests</td>
                            <td>Custom HPA</td>
                        </tr>
                        <tr>
                            <td><strong>Response Time</strong></td>
                            <td>> 3 seconds</td>
                            <td>< 1 second</td>
                            <td>1-2 seconds</td>
                            <td>Alert + Scale</td>
                        </tr>
                    </tbody>
                </table>
            </div>

