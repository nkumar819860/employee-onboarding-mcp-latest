        <div class="header">
            <h1>🌩️ Azure/AWS RTF Capacity Planning & Cost Estimation</h1>
            <div class="subtitle">Comprehensive capacity planning for MuleSoft Runtime Fabric on Azure AKS and AWS EKS with detailed cost analysis and optimization strategies</div>
        </div>

        <div class="content">
            <div class="alert alert-info">
                <strong>☁️ Cloud RTF Planning Overview:</strong> Strategic capacity planning for Runtime Fabric deployments on Azure AKS and AWS EKS, including infrastructure sizing, cost optimization, and actionable recommendations for the Employee Onboarding Platform.
            </div>

            <!-- Azure AKS RTF Planning -->
            <div class="card">
                <h2>🌐 Azure AKS Runtime Fabric Planning</h2>
                <p>Comprehensive capacity planning and cost estimation for MuleSoft RTF on Microsoft Azure Kubernetes Service.</p>
                
                <h3>🏗️ Infrastructure Sizing Matrix</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Environment</th>
                            <th>Node Pool</th>
                            <th>VM Size</th>
                            <th>Node Count</th>
                            <th>vCPU/Memory</th>
                            <th>Monthly Cost</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Development</strong></td>
                            <td>System + App</td>
                            <td>Standard_D2s_v3</td>
                            <td>3-5</td>
                            <td>6-10 vCPU / 12-20 GB</td>
                            <td>$350-580</td>
                        </tr>
                        <tr>
                            <td><strong>Staging</strong></td>
                            <td>System + App</td>
                            <td>Standard_D4s_v3</td>
                            <td>5-8</td>
                            <td>20-32 vCPU / 40-64 GB</td>
                            <td>$720-1,150</td>
                        </tr>
                        <tr>
                            <td><strong>Production</strong></td>
                            <td>System + App</td>
                            <td>Standard_D8s_v3</td>
                            <td>8-15</td>
                            <td>64-120 vCPU / 128-240 GB</td>
                            <td>$1,440-2,700</td>
                        </tr>
                        <tr>
                            <td><strong>HA Production</strong></td>
                            <td>Multi-Zone</td>
                            <td>Standard_D8s_v3</td>
                            <td>12-20</td>
                            <td>96-160 vCPU / 192-320 GB</td>
                            <td>$2,160-3,600</td>
                        </tr>
                    </tbody>
                </table>

                <div class="yaml-block">
# Azure AKS RTF Capacity Planning Configuration
azure_rtf_configuration:
  "subscription_details":
    region: "East US 2"
    "availability_zones": ["1", "2", "3"]
    resource_group: "rtf-employee-onboarding-rg"
    
  "aks_cluster":
    kubernetes_version: "1.28.5"
    network_policy: "azure"
    load_balancer_sku: "standard"
    
  "node_pools":
    "system_pool":
      name: "rtfsystem"
      vm_size: "Standard_D4s_v3"
      "min_count": 3
      "max_count": 6
      "os_disk_size_gb": 128
      os_disk_type: "Premium_LRS"
      "node_taints": ["rtf=system:NoSchedule"]
      
    "application_pool":
      name: "rtfapps"
      vm_size: "Standard_D8s_v3"
      "min_count": 3
      "max_count": 15
      "os_disk_size_gb": 256
      os_disk_type: "Premium_LRS"
      "enable_auto_scaling": true
      
  networking:
    vnet_address_space: "10.240.0.0/16"
    subnet_address_prefix: "10.240.0.0/24"
    service_cidr: "10.241.0.0/16"
    dns_service_ip: "10.241.0.10"
    
  storage:
    storage_class: "managed-premium"
    "backup_retention_days": 30
    
  "estimated_costs":
    compute: "$1,800/month"
    storage: "$300/month"
    networking: "$150/month"
    load_balancer: "$80/month"
    total: "$2,330/month"</div>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value">$2,330</div>
                        <div class="stat-label">Monthly Cost (Prod)</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">3-15</div>
                        <div class="stat-label">Node Scaling Range</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">99.9%</div>
                        <div class="stat-label">SLA Availability</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">3 AZ</div>
                        <div class="stat-label">High Availability</div>
                    </div>
                </div>
            </div>

            <!-- AWS EKS RTF Planning -->
            <div class="card">
                <h2>☁️ AWS EKS Runtime Fabric Planning</h2>
                <p>Detailed capacity planning and cost analysis for MuleSoft RTF on Amazon Elastic Kubernetes Service.</p>
                
                <h3>📊 EC2 Instance Sizing Strategy</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Environment</th>
                            <th>Instance Type</th>
                            <th>Instance Count</th>
                            <th>vCPU/Memory</th>
                            <th>Storage</th>
                            <th>Monthly Cost</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Development</strong></td>
                            <td>t3.large</td>
                            <td>3-4</td>
                            <td>6-8 vCPU / 16-32 GB</td>
                            <td>100 GB gp3</td>
                            <td>$200-270</td>
                        </tr>
                        <tr>
                            <td><strong>Staging</strong></td>
                            <td>m5.xlarge</td>
                            <td>4-6</td>
                            <td>16-24 vCPU / 64-96 GB</td>
                            <td>200 GB gp3</td>
                            <td>$460-690</td>
                        </tr>
                        <tr>
                            <td><strong>Production</strong></td>
                            <td>m5.2xlarge</td>
                            <td>6-12</td>
                            <td>48-96 vCPU / 192-384 GB</td>
                            <td>500 GB gp3</td>
                            <td>$920-1,840</td>
                        </tr>
                        <tr>
                            <td><strong>HA Production</strong></td>
                            <td>m5.2xlarge + c5.2xlarge</td>
                            <td>9-18</td>
                            <td>72-144 vCPU / 288-576 GB</td>
                            <td>1 TB gp3</td>
                            <td>$1,380-2,760</td>
                        </tr>
                    </tbody>
                </table>

                <div class="config-block">
# AWS EKS RTF Infrastructure Configuration
aws_rtf_configuration:
  region: "us-east-1"
  "availability_zones": ["us-east-1a", "us-east-1b", "us-east-1c"]
  
  "eks_cluster":
    version: "1.28"
    "endpoint_private_access": true
    "endpoint_public_access": true
    "cluster_log_types": ["api", "audit", "authenticator"]
    
  "managed_node_groups":
    "rtf_system_nodes":
      "instance_types": ["m5.large", "m5.xlarge"]
      capacity_type: "ON_DEMAND"
      "min_size": 2
      "max_size": 5
      "desired_size": 3
      "disk_size": 100
      
    "rtf_application_nodes":
      "instance_types": ["m5.2xlarge", "c5.2xlarge", "r5.2xlarge"]
      capacity_type: "SPOT"
      "min_size": 3
      "max_size": 15
      "desired_size": 6
      "disk_size": 200
      
  networking:
    vpc_cidr: "10.0.0.0/16"
    "private_subnets": ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
    "public_subnets": ["10.0.101.0/24", "10.0.102.0/24", "10.0.103.0/24"]
    
  "cost_breakdown":
    eks_control_plane: "$73/month"
    ec2_instances: "$920-1,840/month"
    ebs_storage: "$50-200/month"
    data_transfer: "$100-300/month"
    load_balancer: "$22/month"
    total_range: "$1,165-2,435/month"</div>

