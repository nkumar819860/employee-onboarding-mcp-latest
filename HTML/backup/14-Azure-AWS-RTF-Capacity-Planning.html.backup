            <!-- Performance Optimization Strategies -->
            <div class="card">
                <h2>🚀 Performance & Cost Optimization</h2>
                <p>Advanced strategies to optimize both performance and costs for cloud RTF deployments.</p>
                
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin: 2rem 0;">
                    <div class="alert alert-warning">
                        <h4>⚡ Azure Optimization</h4>
                        <ul>
                            <li>Use Azure Reserved Instances (3-year)</li>
                            <li>Implement Azure Spot VMs for dev/test</li>
                            <li>Enable cluster autoscaler</li>
                            <li>Optimize storage tier selection</li>
                            <li>Use Azure Policy for governance</li>
                        </ul>
                    </div>
                    
                    <div class="alert alert-info">
                        <h4>⚡ AWS Optimization</h4>
                        <ul>
