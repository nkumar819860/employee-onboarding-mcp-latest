# Employee Onboarding Agent Fabric - Environment Configuration
# Docker Compose Environment Variables

# ===========================================
# DATABASE CONFIGURATION (PostgreSQL)
# ===========================================
DB_POSTGRES_HOST=postgres
DB_POSTGRES_PORT=5432
DB_POSTGRES_USER=postgres
DB_POSTGRES_PASSWORD=EmployeeOnboarding2024!

# Individual Database Names
EMPLOYEE_DB_NAME=employee_onboarding
ASSET_DB_NAME=asset_allocation
NOTIFICATION_DB_NAME=notification

# Database User Credentials (per service)
EMPLOYEE_DB_USER=employee_user
EMPLOYEE_DB_PASSWORD=employee_pass123
ASSET_DB_USER=asset_user  
ASSET_DB_PASSWORD=asset_pass123

# ===========================================
# HTTP/SERVER CONFIGURATION
# ===========================================
HTTP_HOST=0.0.0.0

# MCP Service Ports
EMPLOYEE_HTTP_PORT=8081
ASSET_HTTP_PORT=8082
NOTIFICATION_HTTP_PORT=8083
AGENT_BROKER_HTTP_PORT=8080

# ===========================================
# EMAIL/NOTIFICATION CONFIGURATION
# ===========================================
# Gmail SMTP Configuration
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_USERNAME=your-email@gmail.com
GMAIL_PASSWORD=your-app-password
GMAIL_FROM_ADDRESS=your-email@gmail.com

# ===========================================
# ANYPOINT PLATFORM CREDENTIALS
# ===========================================
# MuleSoft Connected App Credentials (for deployment)
ANYPOINT_USERNAME=your-username
ANYPOINT_PASSWORD=your-password
ANYPOINT_CLIENT_ID=your-client-id
ANYPOINT_CLIENT_SECRET=your-client-secret
ANYPOINT_ENVIRONMENT=Sandbox
ANYPOINT_BUSINESS_GROUP=your-business-group
ANYPOINT_ORGANIZATION_ID=your-org-id

# ===========================================
# AGENT FABRIC NLP CONFIGURATION
# ===========================================
# Agent Fabric Service URLs
AGENT_FABRIC_BASE_URL=http://agent-broker-mcp:8080
AGENT_FABRIC_NLP_ENDPOINT=/api/nlp/process
AGENT_FABRIC_ORCHESTRATION_ENDPOINT=/api/orchestrate

# NLP Processing Configuration
NLP_MAX_TOKENS=4096
NLP_TIMEOUT=30000
NLP_RETRY_ATTEMPTS=3

# ===========================================
# REACT CLIENT CONFIGURATION
# ===========================================
# API Endpoints for React Client
REACT_APP_API_BASE_URL=http://localhost:8080
REACT_APP_EMPLOYEE_API_URL=http://localhost:8081
REACT_APP_ASSET_API_URL=http://localhost:8082
REACT_APP_NOTIFICATION_API_URL=http://localhost:8083

# Environment Settings
NODE_ENV=development
REACT_APP_ENV=docker
REACT_APP_DEBUG=true

# ===========================================
# DOCKER NETWORK CONFIGURATION
# ===========================================
NETWORK_SUBNET=172.25.0.0/16

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL=INFO
ENABLE_DEBUG_LOGS=true
LOG_TO_FILE=true
LOG_FILE_PATH=/var/log/employee-onboarding/
